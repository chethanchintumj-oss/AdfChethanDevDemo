{
	"name": "Raw2proces_Territorry",
	"properties": {
		"folder": {
			"name": "Sql2Blob_ETL"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Teritory_DS",
						"type": "DatasetReference"
					},
					"name": "SourceTeritory"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "TeritorySink_DS",
						"type": "DatasetReference"
					},
					"name": "sinkTeritory"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SourceTeritory",
				"SourceTeritory sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkTeritory"
			]
		}
	}
}